# Copy to .env.local and fill in. Never commit .env.local.

# Supabase — create project at https://supabase.com, grab from dashboard > API
NEXT_PUBLIC_SUPABASE_URL=
NEXT_PUBLIC_SUPABASE_ANON_KEY=
SUPABASE_SERVICE_ROLE_KEY=
SUPABASE_DB_PASSWORD=

# Resend — transactional email (demo + waitlist forms)
RESEND_API_KEY=

# Stripe — pilot payment collection (Phase 2, stub for now)
STRIPE_PUBLISHABLE_KEY=
STRIPE_SECRET_KEY=

# Analytics
NEXT_PUBLIC_PLAUSIBLE_DOMAIN=
